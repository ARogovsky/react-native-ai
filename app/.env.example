EXPO_PUBLIC_ENV="DEVELOPMENT"

# ELLI backend (services/api behind Cloudflare). SSE chat at /api/openai.
EXPO_PUBLIC_DEV_API_URL="https://api.e-lli.com"
EXPO_PUBLIC_PROD_API_URL="https://api.e-lli.com"

# Clerk publishable key (public by design). Dev: pk_test_..., prod: pk_live_...
# Real value goes in app/.env (gitignored), not here.
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your-key-here"
